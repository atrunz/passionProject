{
  "name": "localshow",
  "version": "0.1.0",
  "private": true,
  "description": "LocalShow is a lightweight ticketing platform for local venues, DIY shows, bars, and bands.",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --parallel --filter @localshow/api --filter @localshow/web dev",
    "dev:web": "pnpm --filter @localshow/web dev",
    "dev:api": "pnpm --filter @localshow/api dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @localshow/api db:generate",
    "db:migrate": "pnpm --filter @localshow/api db:migrate",
    "db:seed": "pnpm --filter @localshow/api db:seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
